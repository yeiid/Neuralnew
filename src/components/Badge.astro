---
interface Props {
	variant?: 'primary' | 'secondary' | 'outline';
}

const { variant = 'primary' } = Astro.props;

const variants = {
	primary: "background: var(--accent); color: white;",
	secondary: "background: var(--bg-card); color: var(--text-secondary); border: 1px solid var(--border);",
	outline: "background: transparent; color: var(--accent-light); border: 1px solid var(--accent-light);"
};
---

<span class="badge" style={variants[variant]}>
	<slot />
</span>

<style>
	.badge {
		display: inline-flex;
		align-items: center;
		padding: 0.125rem 0.625rem;
		border-radius: 9999px;
		font-size: 0.75rem;
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 0.025em;
		white-space: nowrap;
	}
</style>
