---
import Badge from './Badge.astro';

interface Props {
	post: {
		id: string;
		data: {
			title: string;
			description: string;
			pubDate: Date;
			heroImage?: string;
			category: string;
			author?: string;
		};
	};
}

const { post } = Astro.props;
const formattedDate = post.data.pubDate.toLocaleDateString('es-ES', {
	year: 'numeric',
	month: 'short',
	day: 'numeric',
});
---

<a href={`/noticias/${post.id}`} class="news-card">
	{post.data.heroImage && (
		<div class="card-image">
			<img src={post.data.heroImage} alt={post.data.title} loading="lazy" />
			<div class="category-overlay">
				<Badge>{post.data.category}</Badge>
			</div>
		</div>
	)}
	<div class="card-content">
		<header>
			<div class="metadata">
				<time datetime={post.data.pubDate.toISOString()}>{formattedDate}</time>
				{post.data.author && <span class="separator">•</span>}
				{post.data.author && <span class="author">{post.data.author}</span>}
			</div>
			<h3 class="title">{post.data.title}</h3>
		</header>
		<p class="description">{post.data.description}</p>
		<footer class="card-footer">
			<span class="read-more">Leer más <span>→</span></span>
		</footer>
	</div>
</a>

<style>
	.news-card {
		display: flex;
		flex-direction: column;
		background: var(--bg-card);
		border: 1px solid var(--border);
		border-radius: var(--radius);
		overflow: hidden;
		transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
		height: 100%;
		text-decoration: none;
	}

	.news-card:hover {
		transform: translateY(-4px);
		border-color: var(--accent);
		box-shadow: 0 12px 24px -10px rgba(0, 0, 0, 0.5);
	}

	.card-image {
		width: 100%;
		aspect-ratio: 16/9;
		position: relative;
		overflow: hidden;
	}

	.card-image img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		transition: transform 0.5s ease;
	}

	.news-card:hover .card-image img {
		transform: scale(1.05);
	}

	.category-overlay {
		position: absolute;
		top: 1rem;
		left: 1rem;
		z-index: 10;
	}

	.card-content {
		padding: 1.5rem;
		display: flex;
		flex-direction: column;
		flex: 1;
	}

	.metadata {
		display: flex;
		align-items: center;
		gap: 0.5rem;
		font-size: 0.75rem;
		color: var(--text-muted);
		margin-bottom: 0.75rem;
		font-weight: 500;
	}

	.separator {
		color: var(--border);
	}

	.title {
		font-size: 1.25rem;
		font-weight: 700;
		color: var(--text-primary);
		line-height: 1.3;
		margin-bottom: 0.75rem;
	}

	.description {
		font-size: 0.9rem;
		color: var(--text-secondary);
		line-height: 1.6;
		display: -webkit-box;
		-webkit-line-clamp: 3;
		-webkit-box-orient: vertical;
		overflow: hidden;
		flex: 1;
	}

	.card-footer {
		margin-top: 1.5rem;
		padding-top: 1rem;
		border-top: 1px solid var(--border);
	}

	.read-more {
		font-size: 0.875rem;
		color: var(--accent-light);
		font-weight: 600;
		display: flex;
		align-items: center;
		gap: 0.25rem;
	}

	.read-more span {
		transition: transform 0.2s ease;
	}

	.news-card:hover .read-more span {
		transform: translateX(4px);
	}
</style>
