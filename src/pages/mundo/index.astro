---
import DashboardLayout from '../../layouts/DashboardLayout.astro';
import { getCollection } from 'astro:content';
import NewsList from '../../components/NewsList.astro';

const allNews = await getCollection('news');
const mundoPosts = allNews
	.filter(post => post.data.category.toLowerCase().includes('mundo') || post.data.category.toLowerCase().includes('econom'))
	.sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());
---

<DashboardLayout 
	title="Mundo y Economía - NeuralNews" 
	description="Mercados globales, macroeconomía y su impacto en el sector tecnológico."
>
	<NewsList 
		title="Mundo y Economía" 
		description="Análisis global de las tendencias económicas que definen el rumbo del mercado."
		posts={mundoPosts}
	/>
</DashboardLayout>
