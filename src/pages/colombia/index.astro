---
import DashboardLayout from '../../layouts/DashboardLayout.astro';
import { getCollection } from 'astro:content';
import NewsList from '../../components/NewsList.astro';

const allNews = await getCollection('news');
const colombiaPosts = allNews
	.filter(post => post.data.category.toLowerCase().includes('colombia'))
	.sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());
---

<DashboardLayout 
	title="Ecosistema Colombia - NeuralNews" 
	description="Noticias sobre startups, tecnología e innovación en Colombia."
>
	<NewsList 
		title="Ecosistema Colombia" 
		description="El pulso de la innovación y el emprendimiento en el territorio colombiano."
		posts={colombiaPosts}
	/>
</DashboardLayout>
