---
import { getCollection, render } from 'astro:content';
import DashboardLayout from '../../layouts/DashboardLayout.astro';

export async function getStaticPaths() {
	const posts = await getCollection('news');
	return posts.map((post) => ({
		params: { slug: post.id },
		props: post,
	}));
}

const post = Astro.props;
const { Content } = await render(post);
---

<DashboardLayout title={post.data.title}>
	<article style="max-width: 800px; margin: 0 auto; background: #1e293b; border-radius: 12px; overflow: hidden; box-shadow: 0 10px 15px -3px rgb(0 0 0 / 0.1);">
		{post.data.heroImage && (
			<img width={1200} height={600} src={post.data.heroImage} alt="" style="width: 100%; height: auto; object-fit: cover; aspect-ratio: 2/1;" />
		)}
		<div style="padding: 2.5rem;">
			<div style="display: flex; gap: 1rem; align-items: center; margin-bottom: 1rem;">
				<span style="background: #3b82f6; color: white; padding: 0.25rem 0.75rem; border-radius: 9999px; font-size: 0.875rem; font-weight: 600;">{post.data.category}</span>
				<time style="color: #94a3b8; font-size: 0.9rem;">{post.data.pubDate.toISOString().split('T')[0]}</time>
			</div>
			<h1 style="font-size: 2.5rem; font-weight: 800; color: #f8fafc; margin: 0 0 1rem; line-height: 1.2;">{post.data.title}</h1>
			<p style="font-size: 1.125rem; color: #cbd5e1; font-style: italic; border-left: 4px solid #64748b; padding-left: 1rem; margin-bottom: 2rem;">{post.data.description}</p>
			
			<div class="prose prose-invert" style="color: #cbd5e1; line-height: 1.8; font-size: 1.05rem;">
				<Content />
			</div>
		</div>
	</article>
	
	<style>
		/* Estilos tipográficos mínimos para el contenido Markdown del periódico */
		.prose h2 { color: #f8fafc; font-size: 1.8rem; margin-top: 2rem; margin-bottom: 1rem; }
		.prose h3 { color: #e2e8f0; font-size: 1.4rem; margin-top: 1.5rem; margin-bottom: 0.5rem; }
		.prose p { margin-bottom: 1.25rem; }
		.prose ul, .prose ol { margin-bottom: 1.25rem; padding-left: 1.5rem; }
		.prose li { margin-bottom: 0.5rem; }
		.prose strong { color: #f8fafc; }
	</style>
</DashboardLayout>
