---
import DashboardLayout from '../layouts/DashboardLayout.astro';

// Resumen del inicio
const categorias = [
  { nombre: "Tecnología Global", link: "/tecnologia", color: "#8b5cf6", res: "Últimos avances en IA, frameworks (Astro/Next) y big tech." },
  { nombre: "Ecosistema Colombia", link: "/colombia", color: "#f59e0b", res: "Startups locales, inversión extranjera, Fintech y corporativos." },
  { nombre: "Startups y VC", link: "/startups", color: "#10b981", res: "Fondos de Venture Capital, YC, rondas semilla." },
  { nombre: "Mundo y Economía", link: "/mundo", color: "#ef4444", res: "Mercados globales que impactan la tecnología." }
];
---

<DashboardLayout title="NeuralNews - Inicio">
  <div style="margin-bottom: 2rem;">
    <h2 style="color: #f8fafc;">Selecciona una Sección de Inteligencia</h2>
    <p style="color: #94a3b8;">Navega por las categorías actualizadas diariamente.</p>
  </div>

  <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 2rem;">
    {categorias.map((cat) => (
      <a href={cat.link} style="text-decoration: none; color: inherit;">
        <article style={`background: #1e293b; padding: 1.5rem; border-radius: 12px; box-shadow: 0 4px 6px -1px rgb(0 0 0 / 0.1); border-left: 4px solid ${cat.color}; transition: transform 0.2s;`}>
          <h2 style="font-size: 1.25rem; font-weight: 700; margin: 0 0 0.75rem; color: #f8fafc; line-height: 1.4;">
            {cat.nombre} ↗
          </h2>
          <p style="margin: 0; color: #cbd5e1; font-size: 1rem; line-height: 1.6;">
            {cat.res}
          </p>
        </article>
      </a>
    ))}
  </div>
</DashboardLayout>
