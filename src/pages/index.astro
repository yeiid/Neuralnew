---
import { getCollection } from 'astro:content';
import DashboardLayout from '../layouts/DashboardLayout.astro';
import NewsCard from '../components/NewsCard.astro';
import Badge from '../components/Badge.astro';

const allNews = await getCollection('news');
const latestNews = allNews.sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime()).slice(0, 6);

const categorias = [
  { nombre: "Tecnología", link: "/tecnologia", icon: "🚀", res: "IA, frameworks, big tech y gadgets." },
  { nombre: "Colombia", link: "/colombia", icon: "🇨🇴", res: "Startups, fintech y ecosistema local." },
  { nombre: "Startups", link: "/startups", icon: "💎", res: "VC, rondas de inversión y YC." },
  { nombre: "Mundo", link: "/mundo", icon: "🌍", res: "Economía y mercados generales." }
];
---

<DashboardLayout title="NeuralNews - Inteligencia Tecnológica Diaria">
	<section class="hero-section">
		<Badge variant="outline">Noticias de Hoy</Badge>
		<h1>El pulso de la <span class="text-gradient">innovación</span></h1>
		<p class="hero-text">Análisis profundo sobre tecnología, negocios y el futuro del ecosistema digital.</p>
	</section>

	<section class="categories-grid">
		{categorias.map((cat) => (
			<a href={cat.link} class="category-card">
				<span class="category-icon">{cat.icon}</span>
				<div class="category-info">
					<h3>{cat.nombre}</h3>
					<p>{cat.res}</p>
				</div>
			</a>
		))}
	</section>

	<section class="latest-news">
		<div class="section-header">
			<h2>Últimas Actualizaciones</h2>
			<a href="/noticias" class="view-all">Ver todas <span>→</span></a>
		</div>
		<div class="news-grid">
			{latestNews.map((post) => (
				<NewsCard post={post} />
			))}
		</div>
	</section>

	<style>
		.hero-section {
			text-align: center;
			margin-bottom: 4rem;
			padding: 2rem 0;
		}

		.hero-section h1 {
			font-size: clamp(2.5rem, 8vw, 4rem);
			font-weight: 800;
			margin: 1.5rem 0;
			letter-spacing: -0.02em;
		}

		.text-gradient {
			background: linear-gradient(to right, var(--accent-light), #8b5cf6);
			-webkit-background-clip: text;
			-webkit-text-fill-color: transparent;
		}

		.hero-text {
			font-size: 1.25rem;
			color: var(--text-secondary);
			max-width: 600px;
			margin: 0 auto;
		}

		.categories-grid {
			display: grid;
			grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
			gap: 1.5rem;
			margin-bottom: 5rem;
		}

		.category-card {
			display: flex;
			align-items: flex-start;
			gap: 1.25rem;
			background: var(--bg-card);
			border: 1px solid var(--border);
			padding: 1.5rem;
			border-radius: var(--radius);
			transition: all 0.2s ease;
		}

		.category-card:hover {
			border-color: var(--accent);
			background: rgba(59, 130, 246, 0.05);
			transform: scale(1.02);
		}

		.category-icon {
			font-size: 1.5rem;
			background: var(--bg-main);
			width: 3rem;
			height: 3rem;
			display: flex;
			align-items: center;
			justify-content: center;
			border-radius: 10px;
			border: 1px solid var(--border);
		}

		.category-info h3 {
			font-size: 1.125rem;
			margin-bottom: 0.25rem;
		}

		.category-info p {
			font-size: 0.875rem;
			color: var(--text-muted);
			line-height: 1.4;
		}

		.section-header {
			display: flex;
			justify-content: space-between;
			align-items: flex-end;
			margin-bottom: 2rem;
		}

		.section-header h2 {
			font-size: 2rem;
			font-weight: 700;
		}

		.view-all {
			color: var(--accent-light);
			font-weight: 600;
			font-size: 0.95rem;
			display: flex;
			align-items: center;
			gap: 0.5rem;
		}

		.news-grid {
			display: grid;
			grid-template-columns: repeat(auto-fill, minmax(350px, 1fr));
			gap: 2rem;
		}

		@media (max-width: 640px) {
			.news-grid {
				grid-template-columns: 1fr;
			}
		}
	</style>
</DashboardLayout>
