---
import DashboardLayout from '../../layouts/DashboardLayout.astro';
import { getCollection } from 'astro:content';
import NewsList from '../../components/NewsList.astro';

const allNews = await getCollection('news');
const startupsPosts = allNews
	.filter(post => post.data.category.toLowerCase().includes('startup'))
	.sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());
---

<DashboardLayout 
	title="Startups & VC - NeuralNews" 
	description="Últimas noticias sobre levantamiento de capital, Venture Capital y el ecosistema startup global."
>
	<NewsList 
		title="Startups & VC" 
		description="Análisis de rondas de inversión, unicornios y la nueva economía digital."
		posts={startupsPosts}
	/>
</DashboardLayout>
