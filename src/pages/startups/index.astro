---
import DashboardLayout from '../../layouts/DashboardLayout.astro';
import { getCollection } from 'astro:content';

const todasLasNoticias = await getCollection('news');
const noticiasStartups = todasLasNoticias.filter(n => n.data.category === 'Startups').sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---
<DashboardLayout title="Startups - NeuralNews">
  <div style="margin-bottom: 2rem;">
    <a href="/" style="color: #60a5fa; text-decoration: none;">← Volver al Home</a>
    <h1 style="color: #f8fafc;">🚀 Startups y VC</h1>
    <p style="color: #94a3b8;">Noticias sobre levantamiento de capital, YC y ecosistema B2B.</p>
  </div>
  
  <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 1.5rem;">
    {noticiasStartups.map((news) => (
      <a href={`/noticias/${news.id}`} style="text-decoration: none; color: inherit;">
        <article style="background: #1e293b; padding: 1.5rem; border-radius: 8px; border-top: 4px solid #10b981; transition: transform 0.2s;">
          <time style="font-size: 0.8rem; color: #64748b;">{news.data.pubDate.toISOString().split('T')[0]}</time>
          <h3 style="margin: 0.5rem 0; color: #e2e8f0;">{news.data.title}</h3>
          <p style="font-size: 0.9rem; color: #cbd5e1; line-height: 1.5;">{news.data.description}</p>
        </article>
      </a>
    ))}
  </div>
</DashboardLayout>
