---
import DashboardLayout from '../../layouts/DashboardLayout.astro';
import { getCollection } from 'astro:content';
import NewsList from '../../components/NewsList.astro';

const allNews = await getCollection('news');
const tecnologiaPosts = allNews
	.filter(post => post.data.category.toLowerCase().includes('tecnolog'))
	.sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());
---

<DashboardLayout 
	title="Tecnología Global - NeuralNews" 
	description="Explora las últimas noticias sobre IA, desarrollo de software y el futuro de la tecnología."
>
	<NewsList 
		title="Tecnología Global" 
		description="Análisis profundo de los avances tecnológicos que están moldeando el mañana."
		posts={tecnologiaPosts}
	/>
</DashboardLayout>
